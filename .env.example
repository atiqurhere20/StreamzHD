# ============================================================
# Supabase (required)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================================
# App
# ============================================================
# Final public URL — used for canonical links, OG metadata, sitemap.
NEXT_PUBLIC_APP_URL=https://streamzhd.example.com
NEXT_PUBLIC_APP_NAME=StreamzHD

# ============================================================
# Admin
# ============================================================
# Admin account is seeded by supabase/migrations/007_admin_auth.sql.
# EDIT that file's admin_email + admin_password BEFORE running migrations.
# After first login, change the password from the Supabase dashboard.
# No JWT secret, no bcrypt hash needed — auth is fully Supabase-managed.
